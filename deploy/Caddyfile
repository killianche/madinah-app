# Caddyfile для Madinah App.
# Временно HTTP-only: TimeWeb режет входящий ACME-трафик Let's Encrypt,
# сертификат выдать не получается. Когда перейдём на свой домен с
# нормальным DNS (app.madinah.ru через reg.ru) — вернём автоматический
# HTTPS, просто подменив блок ниже на `app.madinah.ru { ... }`.

{
    auto_https off
    admin off
}

:80 {
    encode zstd gzip

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    reverse_proxy localhost:3000 {
        health_uri /api/health
        health_interval 30s
        health_timeout 5s
    }
}
